# Copy this file to .env.local and fill the values with your Supabase project details.
# Do NOT commit your real .env.local with secrets.

# Supabase (public anon key) - used for read-only client API calls
# .env.local
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# reCAPTCHA - daftar di https://www.google.com/recaptcha/admin
# Pilih reCAPTCHA v2 "I'm not a robot" (Checkbox)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

TOKEN_SECRET=
# Any other environment variables used by the app can be listed here
# NEXT_PUBLIC_SOME_FEATURE_FLAG=1